# PHP Version (options: 7.4, 8.0, 8.1, 8.2, 8.3, 8.4)
# After changing, run: docker compose build php && docker compose up -d php
PHP_VERSION=8.3

# MySQL Configuration (user: root)
# Connect with: mysql -h 127.0.0.1 -u root -p
MYSQL_ROOT_PASSWORD=

# PostgreSQL Configuration
# Connect with: psql -h 127.0.0.1 -U root -d postgres
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
